#pragma once
// ── Standortspezifische Geheimnisse ──────────────────────────────────────────
// Diese Datei nach `secrets.h` kopieren und ausfüllen. `secrets.h` ist per
// .gitignore vom Repo ausgeschlossen (enthält WLAN-Passwort + Renderer-URL).
//
// WLAN muss 2.4 GHz sein (ESP32-S3 kann kein 5 GHz). Bei Fritz!Box meist dieselbe
// SSID für beide Bänder — dann passt es automatisch.
#define WIFI_SSID  "DEIN_WLAN_SSID"
#define WIFI_PASS  "DEIN_WLAN_PASSWORT"

// Renderer-Endpunkt im LAN: Host-IP + Port 8080 + optionaler Shared Key (eink_key).
//
// Home-Assistant-Add-on: das ist die IP des HA-HOSTS mit Port 8080 (der vom Add-on
// via `ports:` direkt exponierte eInk-Port) — NICHT der 8123-Frontend-Port.
// WICHTIG: immer PLAIN HTTP. Auch wenn das HA-Frontend HTTPS nutzt (Port 8123),
// laeuft der Add-on-Port 8080 daran vorbei; der ESP32 spricht kein TLS/keine
// HA-Auth. Endpunkt bleibt also http://<ha-ip>:8080/eink.bin
//
// Shared Key nur noetig, wenn im Add-on die Option `eink_key` gesetzt ist — dann
// ?key=DEIN_KEY anhaengen, sonst den ?key=...-Teil weglassen.
#define IMG_HOST   "192.168.1.100:8080"
#define IMG_URL    "http://192.168.1.100:8080/eink.bin"
