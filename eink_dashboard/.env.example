# eInk-Renderer — Konfiguration. Datei nach .env kopieren und ausfüllen.
# Ohne Keys läuft der Service mit Mock-Daten.

# ── App-Admin-APIs (Server-Metriken + Nutzerzahlen), optional, bis zu zwei Apps ──
APP1_API_KEY=
APP2_API_KEY=
# Admin-/Metrik-Endpunkte nur setzen, falls abweichend vom Default:
# APP1_API_URL=https://your-app.example.com/api/admin/live
# APP2_API_URL=https://your-other-app.example.com/api/admin/live
# Cost-Key-/Produktnamen (Substrings, komma-getrennt), die als API-Kosten App 1
# bzw. App 2 zugeordnet werden (matcht die Namen deiner Venice/OpenRouter-Keys):
# APP_PRIMARY_MATCH=app1name,alternativname
# APP_SECONDARY_MATCH=app2name

# ── Zahlungen & API-Kosten (für MRR / Abos / Gewinn) ──
STRIPE_SECRET_KEY=
VENICE_ADMIN_KEY=
FAL_ADMIN_KEY=
OPENROUTER_ADMIN_KEY=

# ── Service ──
EINK_PORT=8080
# Optionales Shared Secret: wenn gesetzt, muss /eink?key=... übereinstimmen
EINK_KEY=
# Render-Cache in Sekunden (wie oft Quellen frisch geholt werden)
EINK_CACHE_TTL=300
# Zeitzone für Datum/Uhrzeit im Header
EINK_TZ=Europe/Berlin
EINK_WEATHER_CITY=München

# ── iCloud-Kalender (CalDAV, app-spezifisches Passwort) ──
ICLOUD_USER=
ICLOUD_APP_PW=
# Nur diese iCloud-Kalender anzeigen (Anzeigenamen, komma-getrennt; ⚠️/Emojis egal)
# Leer = alle Kalender. Beispiel: ICLOUD_CALENDARS=Familie,Privat
ICLOUD_CALENDARS=
# ── Öffentliche iCal-Feeds (ICS-URLs oder webcal://), komma-getrennt ──
ICAL_URLS=

# ── iCloud-Erinnerungen (moderne Reminders via pyicloud-Bridge) ──
# Apple-ID (falls abweichend von ICLOUD_USER)
ICLOUD_APPLE_ID=
# Nur diese Erinnerungslisten (Name/UUID, komma-getrennt; leer = alle)
ICLOUD_REMINDER_LISTS=
# Pfade zur Python-Bridge (nur lokal noetig; im HA-Add-on automatisch gesetzt):
# REMINDER_BRIDGE_PY=C:\pfad\zu\python.exe
# REMINDER_BRIDGE_SCRIPT=C:\pfad\zu\bridge.py
# Refresh-Intervall der Erinnerungen in Minuten (min. ~2 sinnvoll)
REMINDER_REFRESH_MIN=5